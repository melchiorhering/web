---
// src/sections/ContactForm.astro
import Section from "@components/layout/Section.astro";
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const contactData = t("contact") as any;
---

<Section class="pt-10 pb-20 lg:pt-12 lg:pb-10">
    <div class="mb-6 text-center">
        <h1 class="text-4xl font-heading text-wood-dark mb-4">
            {t("contact.title") || "Let's Build Something"}
        </h1>
        <p class="text-md text-wood-text max-w-2xl mx-auto">
            {
                t("contact.subtitle") ||
                    "Fill out the details below to give us an idea of your project. The estimator will provide a rough starting price, and we'll be in touch to discuss the exact details."
            }
        </p>
    </div>

    <form
        id="contact-form"
        class="grid grid-cols-1 lg:grid-cols-2 gap-2 lg:gap-10 items-start"
    >
        <input
            type="hidden"
            name="access_key"
            value="24f6c6c2-7748-47a0-b94a-b262f37eb375"
        />
        <input
            type="hidden"
            name="subject"
            value={`New Quote Request (${lang.toUpperCase()})`}
        />
        <input type="hidden" name="from_name" value="Timmerman Website" />
        <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display: none;"
        />

        <div
            class="space-y-5 bg-wood-bg p-6 lg:p-8 rounded-md shadow-sm border-2 border-wood-base/20"
        >
            <h2 class="text-2xl font-heading text-wood-dark mb-4">
                {t("contact.formTitle") || "Your Details"}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label
                        for="name"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{t("contact.form.name") || "Full Name"}</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="Name"
                        required
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50 text-wood-text placeholder-wood-text/40"
                    />
                </div>
                <div>
                    <label
                        for="email"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{t("contact.form.email") || "Email Address"}</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="Email"
                        required
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50 text-wood-text placeholder-wood-text/40"
                    />
                </div>
            </div>

            <div>
                <label
                    for="phone"
                    class="block text-sm font-medium text-wood-text mb-2"
                    >{t("contact.form.phone") || "Phone Number"}</label
                >
                <input
                    type="tel"
                    id="phone"
                    name="Phone"
                    required
                    class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50 text-wood-text placeholder-wood-text/40"
                />
            </div>

            <div>
                <label
                    for="description"
                    class="block text-sm font-medium text-wood-text mb-2"
                    >{
                        t("contact.form.description") || "Project Description"
                    }</label
                >
                <textarea
                    id="description"
                    name="Description"
                    rows="5"
                    required
                    placeholder={t("contact.form.placeholder") ||
                        "Tell us about your vision, dimensions, and where it will go..."}
                    class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50 text-wood-text placeholder-wood-text/40 resize-y"
                ></textarea>
            </div>
        </div>

        <div
            class="flex flex-col bg-wood-bg p-6 lg:p-8 rounded-md border-2 border-wood-base/20 sticky top-24 max-h-[calc(100vh-6rem)]"
        >
            <div class="shrink-0 mb-5">
                <h2 class="text-2xl font-heading text-wood-dark mb-2">
                    {t("contact.estimator.title") || "Project Estimator"}
                </h2>
                <p class="text-sm text-wood-text/80">
                    {
                        t("contact.estimator.subtitle") ||
                            "Select your options below to get a rough baseline estimate."
                    }
                </p>
            </div>

            <div class="flex-1 overflow-y-auto space-y-5 pr-2">
                <div>
                    <label
                        for="project-type"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{
                            t("contact.estimator.typeLabel") ||
                                "Type of Project"
                        }</label
                    >
                    <select
                        id="project-type"
                        name="Project Type"
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base outline-none bg-wood-bg text-wood-text estimator-input"
                    >
                        {
                            contactData.estimator?.projectTypes?.map(
                                (type: any) => (
                                    <option
                                        value={type.label}
                                        data-base={type.basePrice}
                                    >
                                        {type.label}
                                    </option>
                                ),
                            )
                        }
                    </select>
                </div>

                <div>
                    <label
                        for="material"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{
                            t("contact.estimator.materialLabel") ||
                                "Preferred Material"
                        }</label
                    >
                    <select
                        id="material"
                        name="Material"
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base outline-none bg-wood-bg text-wood-text estimator-input"
                    >
                        {
                            contactData.estimator?.materials?.map(
                                (material: any) => (
                                    <option
                                        value={material.label}
                                        data-mult={material.multiplier}
                                    >
                                        {material.label}
                                    </option>
                                ),
                            )
                        }
                    </select>
                </div>

                <div>
                    <label
                        for="size"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{
                            t("contact.estimator.sizeLabel") ||
                                "Approximate Size"
                        }</label
                    >
                    <select
                        id="size"
                        name="Size"
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base outline-none bg-wood-bg text-wood-text estimator-input"
                    >
                        {
                            contactData.estimator?.sizes?.map((size: any) => (
                                <option
                                    value={size.label}
                                    data-mult={size.multiplier}
                                >
                                    {size.label}
                                </option>
                            ))
                        }
                    </select>
                </div>
            </div>

            <div class="shrink-0 mt-6 pt-5 border-t border-wood-light/30">
                <p
                    class="text-sm font-medium text-wood-text/80 uppercase tracking-wider mb-1"
                >
                    {
                        t("contact.estimator.estimateLabel") ||
                            "Estimated Starting Price"
                    }
                </p>
                <div
                    class="text-4xl lg:text-5xl font-heading text-wood-dark flex items-baseline gap-2"
                >
                    <span>€</span>
                    <span id="price-display">0</span>
                    <span class="text-xl text-wood-text/60 font-sans">+</span>
                </div>
                <p class="text-xs text-wood-text/60 mt-2 mb-5 leading-relaxed">
                    {
                        t("contact.estimator.disclaimer") ||
                            "*This is a rough baseline estimate for materials and labor. Final quotes require a detailed consultation."
                    }
                </p>

                <button
                    id="submit-btn"
                    type="submit"
                    class="w-full px-8 py-3.5 bg-wood-base text-wood-bg font-medium rounded-sm hover:bg-wood-dark transition-colors duration-300 text-lg shadow-sm flex justify-center items-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
                >
                    <span
                        id="btn-text"
                        data-original-text={t("contact.form.submit") ||
                            "Submit Request"}
                        >{t("contact.form.submit") || "Submit Request"}</span
                    >
                    <svg
                        id="btn-spinner"
                        class="hidden animate-spin h-5 w-5 text-wood-bg"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <circle
                            class="opacity-25"
                            cx="12"
                            cy="12"
                            r="10"
                            stroke="currentColor"
                            stroke-width="4"></circle>
                        <path
                            class="opacity-75"
                            fill="currentColor"
                            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                        ></path>
                    </svg>
                </button>

                <div
                    id="form-success"
                    class="hidden mt-4 p-4 bg-green-50/50 border border-green-200 rounded-sm flex items-start gap-3 dark:bg-green-900/10 dark:border-green-800/50"
                >
                    <Icon
                        name="lucide:check-circle"
                        class="w-5 h-5 text-green-800 shrink-0 mt-0.5"
                    />
                    <p class="text-sm text-green-800">
                        {
                            t("contact.form.success") ||
                                "Thank you! Your request has been sent successfully. I will be in touch soon."
                        }
                    </p>
                </div>

                <div
                    id="form-error"
                    class="hidden mt-4 p-4 bg-red-50/50 border border-red-500 rounded-sm flex items-start gap-3 dark:bg-red-900/10 dark:border-red-800/50"
                >
                    <Icon
                        name="lucide:alert-circle"
                        class="w-5 h-5 text-red-500 shrink-0 mt-0.5"
                    />
                    <p class="text-sm text-red-500">
                        {
                            t("contact.form.error") ||
                                "Oops! Something went wrong. Please try again later or contact me directly via email."
                        }
                    </p>
                </div>
            </div>
        </div>
    </form>
</Section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- ESTIMATOR LOGIC (Unchanged) ---
        const typeSelect = document.getElementById(
            "project-type",
        ) as HTMLSelectElement;
        const materialSelect = document.getElementById(
            "material",
        ) as HTMLSelectElement;
        const sizeSelect = document.getElementById("size") as HTMLSelectElement;
        const priceDisplay = document.getElementById("price-display");

        function calculatePrice() {
            if (!typeSelect || !materialSelect || !sizeSelect) return;
            const selectedType = typeSelect.options[typeSelect.selectedIndex];
            const selectedMaterial =
                materialSelect.options[materialSelect.selectedIndex];
            const selectedSize = sizeSelect.options[sizeSelect.selectedIndex];

            const basePrice = parseFloat(
                selectedType?.getAttribute("data-base") || "0",
            );
            const materialMultiplier = parseFloat(
                selectedMaterial?.getAttribute("data-mult") || "1",
            );
            const sizeMultiplier = parseFloat(
                selectedSize?.getAttribute("data-mult") || "1",
            );

            const total = basePrice * materialMultiplier * sizeMultiplier;

            let start = parseInt(
                (priceDisplay!.textContent || "0").replace(/,/g, ""),
            );
            const end = Math.round(total);
            const duration = 300;
            const steps = 15;
            const stepTime = Math.abs(Math.floor(duration / steps));
            const increment = (end - start) / steps;

            let current = start;
            const timer = setInterval(() => {
                current += increment;
                priceDisplay!.textContent =
                    Math.round(current).toLocaleString("en-NL");
                if (
                    (increment > 0 && current >= end) ||
                    (increment < 0 && current <= end)
                ) {
                    priceDisplay!.textContent = end.toLocaleString("en-NL");
                    clearInterval(timer);
                }
            }, stepTime);
        }

        const inputs = document.querySelectorAll(".estimator-input");
        inputs.forEach((input) => {
            input.addEventListener("change", calculatePrice);
        });

        setTimeout(calculatePrice, 50);

        // --- UPDATED FORM SUBMISSION LOGIC ---
        const form = document.getElementById("contact-form") as HTMLFormElement;
        const submitBtn = document.getElementById(
            "submit-btn",
        ) as HTMLButtonElement;
        const btnText = document.getElementById("btn-text") as HTMLSpanElement;
        const btnSpinner = document.getElementById(
            "btn-spinner",
        ) as HTMLElement;

        const formSuccess = document.getElementById(
            "form-success",
        ) as HTMLDivElement;
        const formError = document.getElementById(
            "form-error",
        ) as HTMLDivElement;

        form.addEventListener("submit", async function (e) {
            e.preventDefault();

            // Store original text so it properly reverts to Dutch or English
            const originalText =
                btnText.getAttribute("data-original-text") || "Submit";

            // Set Loading State
            submitBtn.disabled = true;
            btnText.textContent = "..."; // Keep it short and neutral during loading
            btnSpinner.classList.remove("hidden");
            formSuccess.classList.add("hidden");
            formError.classList.add("hidden");

            const formData = new FormData(form);

            if (priceDisplay) {
                formData.append(
                    "Calculated Estimate",
                    `€${priceDisplay.textContent}+`,
                );
            }

            try {
                const response = await fetch(
                    "https://api.web3forms.com/submit",
                    {
                        method: "POST",
                        body: formData,
                    },
                );

                if (response.ok) {
                    // Success State
                    form.reset();
                    formSuccess.classList.remove("hidden");
                    calculatePrice();
                } else {
                    throw new Error("Something went wrong");
                }
            } catch (error) {
                // Error State
                formError.classList.remove("hidden");
            } finally {
                // Reset Button
                submitBtn.disabled = false;
                btnText.textContent = originalText;
                btnSpinner.classList.add("hidden");
            }
        });
    });
</script>
