---
// src/components/ProjectGallery.astro
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

interface Props {
    title: string;
    carouselImages: any[];
    galleryImages: any[];
}

const { title, carouselImages, galleryImages } = Astro.props;
---

{/* --- DYNAMIC COVER SLIDESHOW --- */}
{
    carouselImages.length > 0 && (
        <div class="relative w-full rounded-md overflow-hidden mb-16 bg-wood-light/5 border border-wood-light/20 shadow-sm group/slider">
            <div id="cover-slider-track" class="flex h-full touch-pan-y">
                {carouselImages.map((img, index) => (
                    <div
                        class="w-full shrink-0 flex justify-center py-8 relative group"
                        data-slide={index}
                    >
                        <Image
                            src={img}
                            alt={`View ${index + 1} of ${title}`}
                            class="w-full max-w-250 h-auto max-h-[65vh] object-contain rounded-sm drop-shadow-md cursor-pointer lightbox-trigger transition-transform duration-700 group-hover:scale-[1.01]"
                            width={1200}
                            height={675}
                        />
                        <div class="absolute inset-0 pointer-events-none flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 group-hover:bg-wood-dark/10">
                            <div class="bg-wood-bg/95 text-wood-dark p-4 rounded-full shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                <Icon name="lucide:zoom-in" class="w-6 h-6" />
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            {carouselImages.length > 1 && (
                <>
                    <button
                        id="slider-prev"
                        class="absolute left-4 top-1/2 -translate-y-1/2 bg-wood-bg/90 hover:bg-wood-bg text-wood-dark p-3 rounded-full shadow-md opacity-0 group-hover/slider:opacity-100 transition-all duration-300 hover:scale-110 focus:outline-none"
                        aria-label="Previous image"
                    >
                        <Icon name="lucide:chevron-left" class="w-6 h-6" />
                    </button>
                    <button
                        id="slider-next"
                        class="absolute right-4 top-1/2 -translate-y-1/2 bg-wood-bg/90 hover:bg-wood-bg text-wood-dark p-3 rounded-full shadow-md opacity-0 group-hover/slider:opacity-100 transition-all duration-300 hover:scale-110 focus:outline-none"
                        aria-label="Next image"
                    >
                        <Icon name="lucide:chevron-right" class="w-6 h-6" />
                    </button>

                    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
                        {carouselImages.map((_, idx) => (
                            <button
                                class="slider-dot w-2.5 h-2.5 rounded-full transition-all duration-300 focus:outline-none"
                                data-target={idx}
                                aria-label={`Go to slide ${idx + 1}`}
                            />
                        ))}
                    </div>
                </>
            )}
        </div>
    )
}

{/* --- MASONRY GALLERY --- */}
{
    galleryImages.length > 0 && (
        <div class="mt-8">
            <div class="flex items-center gap-4 mb-8">
                <h2 class="text-2xl font-heading text-wood-dark m-0">
                    Project Gallery
                </h2>
                <div class="h-px bg-wood-light/40 flex-1 mt-1" />
            </div>
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
                {galleryImages.map((img, index) => (
                    <div class="relative group rounded-md overflow-hidden bg-wood-light/10 shadow-sm border border-wood-light/20 break-inside-avoid">
                        <Image
                            src={img}
                            alt={`Detail shot ${index + 1} of ${title}`}
                            class="w-full h-auto object-cover cursor-pointer lightbox-trigger transition-transform duration-700 group-hover:scale-105"
                            width={800}
                            height={800}
                        />
                        <div class="absolute inset-0 pointer-events-none flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 group-hover:bg-wood-dark/20">
                            <div class="bg-wood-bg/95 text-wood-dark p-3 rounded-full shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                <Icon name="lucide:zoom-in" class="w-5 h-5" />
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    )
}

{/* --- UPGRADED LIGHTBOX UI --- */}
<dialog
    id="lightbox"
    class="bg-transparent m-auto max-w-[100vw] max-h-screen w-full h-full p-4 md:p-8 backdrop:bg-black/95 backdrop:backdrop-blur-sm focus:outline-none touch-none"
>
    <button
        id="lightbox-close"
        class="fixed top-6 right-6 md:top-10 md:right-10 text-white/80 hover:text-white transition-colors z-50 focus:outline-none"
        aria-label="Close fullscreen image"
    >
        <Icon name="lucide:x" class="w-10 h-10 drop-shadow-md" />
    </button>

    <button
        id="lightbox-prev"
        class="fixed left-2 sm:left-6 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors z-50 focus:outline-none hidden sm:block"
        aria-label="Previous image"
    >
        <Icon name="lucide:chevron-left" class="w-12 h-12 drop-shadow-lg" />
    </button>

    <button
        id="lightbox-next"
        class="fixed right-2 sm:right-6 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors z-50 focus:outline-none hidden sm:block"
        aria-label="Next image"
    >
        <Icon name="lucide:chevron-right" class="w-12 h-12 drop-shadow-lg" />
    </button>

    <div class="w-full h-full flex items-center justify-center">
        <img
            id="lightbox-img"
            src=""
            alt="Fullscreen view"
            class="max-w-full max-h-full object-contain rounded-sm shadow-2xl scale-95 opacity-0 transition-all duration-300 select-none"
            draggable="false"
        />
    </div>
</dialog>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- 0. SWIPE HELPER UTILITY ---
        const addSwipeListener = (
            element: HTMLElement,
            onSwipeLeft: () => void,
            onSwipeRight: () => void,
        ) => {
            let touchStartX = 0;
            let touchEndX = 0;
            const threshold = 40; // Minimum pixel drag to trigger a swipe

            element.addEventListener(
                "touchstart",
                (e) => {
                    touchStartX = e.changedTouches[0].screenX;
                },
                { passive: true },
            );

            element.addEventListener(
                "touchend",
                (e) => {
                    touchEndX = e.changedTouches[0].screenX;
                    if (touchStartX - touchEndX > threshold) onSwipeLeft(); // Swipe Left -> Next
                    if (touchEndX - touchStartX > threshold) onSwipeRight(); // Swipe Right -> Prev
                },
                { passive: true },
            );
        };

        // --- 1. LIGHTBOX LOGIC ---
        const dialog = document.getElementById("lightbox") as HTMLDialogElement;
        const dialogImg = document.getElementById(
            "lightbox-img",
        ) as HTMLImageElement;
        const closeBtn = document.getElementById("lightbox-close");
        const lbPrevBtn = document.getElementById("lightbox-prev");
        const lbNextBtn = document.getElementById("lightbox-next");

        const triggers = Array.from(
            document.querySelectorAll(".lightbox-trigger"),
        ) as HTMLImageElement[];

        triggers.forEach((trigger, idx) => {
            trigger.setAttribute("data-lb-index", idx.toString());
        });

        let currentLightboxIndex = 0;

        const openLightbox = (index: number) => {
            if (!dialog || !dialogImg) return;
            currentLightboxIndex = index;
            const targetImg = triggers[currentLightboxIndex];

            dialogImg.src = targetImg.src;
            dialogImg.alt = targetImg.alt;
            dialog.showModal();
            document.body.style.overflow = "hidden";
            setTimeout(() => {
                dialogImg.classList.remove("scale-95", "opacity-0");
                dialogImg.classList.add("scale-100", "opacity-100");
            }, 10);
        };

        document.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            const trigger = target.closest(
                ".lightbox-trigger",
            ) as HTMLImageElement;
            if (trigger) {
                const idx = parseInt(
                    trigger.getAttribute("data-lb-index") || "0",
                    10,
                );
                openLightbox(idx);
            }
        });

        const changeLightboxImage = (direction: "next" | "prev") => {
            if (direction === "next") {
                currentLightboxIndex =
                    (currentLightboxIndex + 1) % triggers.length;
            } else {
                currentLightboxIndex =
                    (currentLightboxIndex - 1 + triggers.length) %
                    triggers.length;
            }

            dialogImg.classList.remove("opacity-100", "scale-100");
            dialogImg.classList.add("opacity-0", "scale-95");
            setTimeout(() => {
                const targetImg = triggers[currentLightboxIndex];
                dialogImg.src = targetImg.src;
                dialogImg.alt = targetImg.alt;

                dialogImg.classList.remove("opacity-0", "scale-95");
                dialogImg.classList.add("opacity-100", "scale-100");
            }, 200);
        };

        if (dialog && dialogImg) {
            const closeLightbox = () => {
                dialogImg.classList.remove("scale-100", "opacity-100");
                dialogImg.classList.add("scale-95", "opacity-0");
                setTimeout(() => {
                    dialog.close();
                    document.body.style.overflow = "";
                    dialogImg.src = "";
                }, 300);
            };

            closeBtn?.addEventListener("click", closeLightbox);
            lbNextBtn?.addEventListener("click", () =>
                changeLightboxImage("next"),
            );
            lbPrevBtn?.addEventListener("click", () =>
                changeLightboxImage("prev"),
            );
            dialog.addEventListener("click", (e) => {
                if (e.target === dialog) closeLightbox();
            });
            dialog.addEventListener("cancel", (e) => {
                e.preventDefault();
                closeLightbox();
            });

            // ADD SWIPE TO LIGHTBOX
            addSwipeListener(
                dialog,
                () => changeLightboxImage("next"),
                () => changeLightboxImage("prev"),
            );
        }

        // --- 2. INFINITE SLIDER LOGIC ---
        const track = document.getElementById("cover-slider-track");
        const prevBtn = document.getElementById("slider-prev");
        const nextBtn = document.getElementById("slider-next");
        const dots = document.querySelectorAll(".slider-dot");

        if (track && dots.length > 1) {
            const slides = Array.from(track.children);
            const firstClone = slides[0].cloneNode(true);
            const lastClone = slides[slides.length - 1].cloneNode(true);

            track.appendChild(firstClone);
            track.insertBefore(lastClone, slides[0]);

            let currentSlide = 1;
            const realTotalSlides = dots.length;
            let isAnimating = false;

            track.style.transform = `translateX(-${currentSlide * 100}%)`;

            const updateSliderDots = () => {
                let dotIndex = currentSlide - 1;
                if (currentSlide === 0) dotIndex = realTotalSlides - 1;
                if (currentSlide === realTotalSlides + 1) dotIndex = 0;
                dots.forEach((dot, idx) => {
                    if (idx === dotIndex) {
                        dot.classList.add("bg-wood-dark", "scale-110");
                        dot.classList.remove("bg-wood-dark/30");
                    } else {
                        dot.classList.remove("bg-wood-dark", "scale-110");
                        dot.classList.add("bg-wood-dark/30");
                    }
                });
            };

            const moveToSlide = (index: number) => {
                if (isAnimating) return;
                isAnimating = true;
                currentSlide = index;
                track.style.transition = "transform 0.5s ease-out";
                track.style.transform = `translateX(-${currentSlide * 100}%)`;
                updateSliderDots();
            };

            nextBtn?.addEventListener("click", () =>
                moveToSlide(currentSlide + 1),
            );
            prevBtn?.addEventListener("click", () =>
                moveToSlide(currentSlide - 1),
            );
            dots.forEach((dot, idx) => {
                dot.addEventListener("click", () => moveToSlide(idx + 1));
            });

            track.addEventListener("transitionend", () => {
                isAnimating = false;
                if (currentSlide === 0) {
                    track.style.transition = "none";
                    currentSlide = realTotalSlides;
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                }
                if (currentSlide === realTotalSlides + 1) {
                    track.style.transition = "none";
                    currentSlide = 1;
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                }
            });
            updateSliderDots();

            // ADD SWIPE TO SLIDER
            addSwipeListener(
                track,
                () => {
                    if (!isAnimating) moveToSlide(currentSlide + 1);
                },
                () => {
                    if (!isAnimating) moveToSlide(currentSlide - 1);
                },
            );
        }

        // --- 3. GLOBAL KEYBOARD NAVIGATION ---
        document.addEventListener("keydown", (e) => {
            if (dialog && dialog.open) {
                if (e.key === "ArrowRight") changeLightboxImage("next");
                if (e.key === "ArrowLeft") changeLightboxImage("prev");
            } else if (track && dots.length > 1) {
                if (e.key === "ArrowRight") nextBtn?.click();
                if (e.key === "ArrowLeft") prevBtn?.click();
            }
        });
    });
</script>
