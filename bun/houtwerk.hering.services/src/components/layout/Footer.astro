---
// src/components/layout/Footer.astro
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "@i18n/utils";

const currentYear = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const siteData = t("site") as any;
const contactData = t("contact") as any;

// Dynamically grab the current domain and URL
const displayDomain = Astro.url.hostname;
const siteOrigin = Astro.url.origin;
---

<footer
    class="w-full bg-wood-bg border-t border-wood-light/20 text-wood-text py-16 mt-12"
>
    <div
        class="max-w-300 mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-8"
    >
        <div class="flex flex-col space-y-4">
            <a
                href={translatePath("/")}
                class="flex items-center gap-3 group w-fit"
            >
                <img
                    src="/images/default-og.jpg"
                    alt={`${siteData.brandName} Logo`}
                    class="w-10 rounded-sm shadow-sm group-hover:shadow transition-shadow"
                />
                <h3 class="text-2xl font-heading text-wood-dark m-0">
                    {siteData.brandName}
                </h3>
            </a>

            <p class="text-wood-text/80 text-sm max-w-xs leading-relaxed">
                {siteData.description}
            </p>
        </div>

        <div>
            <h4
                class="font-bold mb-4 uppercase text-sm tracking-wider text-wood-dark"
            >
                {t("footer.quickLinks") || "Quick Links"}
            </h4>
            <ul class="space-y-3 text-sm text-wood-text/80">
                {
                    siteData.navLinks.map((link: any) => (
                        <li>
                            <a
                                href={link.href}
                                class="hover:text-wood-base transition-colors"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>

        <div>
            <h4
                class="font-bold mb-4 uppercase text-sm tracking-wider text-wood-dark"
            >
                {t("footer.contact") || "Contact"}
            </h4>

            <address class="not-italic text-sm text-wood-text/80 space-y-2">
                <p class="font-medium text-wood-dark">{siteData.ownerName}</p>
                <p>{siteData.brandName}</p>
                <p>
                    <a
                        href={`mailto:${contactData.email}`}
                        class="hover:text-wood-base transition-colors"
                    >
                        {contactData.email}
                    </a>
                </p>
                <p>
                    <a
                        href={siteOrigin}
                        class="hover:text-wood-base transition-colors"
                    >
                        {displayDomain}
                    </a>
                </p>
            </address>
        </div>
    </div>

    <div
        class="max-w-300 mx-auto px-6 mt-16 pt-8 border-t border-wood-light/20 text-center text-sm text-wood-text/60"
    >
        &copy; {currentYear}
        {siteData.brandName}. {t("footer.rights") || "All rights reserved."}
    </div>
</footer>
