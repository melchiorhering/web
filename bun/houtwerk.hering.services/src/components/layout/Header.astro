---
// src/components/layout/Header.astro
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "@i18n/utils";
import { Icon } from "astro-icon/components";
import LanguagePicker from "@components/LanguagePicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<header
    class="sticky top-0 z-50 w-full bg-wood-bg/90 backdrop-blur-md border-b border-wood-light/20"
>
    <div class="max-w-300 mx-auto px-6 h-20 flex items-center justify-between">
        <a href={translatePath("/")} class="flex items-center gap-3 group">
            <img
                src="/images/default-og.jpg"
                alt="Logo"
                class="w-12 rounded-sm"
            />
            <span
                class="text-2xl font-heading font-bold text-wood-dark hidden sm:block"
            >
                {t("site.brandName")}
            </span>
        </a>

        <div class="hidden md:flex items-center gap-8">
            <nav class="flex items-center gap-6">
                {
                    t("site.navLinks").map((link: any) => (
                        <a
                            href={translatePath(link.href)}
                            class="text-wood-text hover:text-wood-base font-medium transition-colors"
                        >
                            {link.label}
                        </a>
                    ))
                }
            </nav>

            <div
                class="flex items-center gap-6 border-l border-wood-light/30 pl-6"
            >
                <LanguagePicker />
                <button
                    id="theme-toggle"
                    class="text-wood-text hover:text-wood-base focus:outline-none"
                    aria-label="Toggle Dark Mode"
                >
                    <Icon name="lucide:sun" class="w-5 h-5 theme-icon-sun" />
                    <Icon name="lucide:moon" class="w-5 h-5 theme-icon-moon" />
                </button>
                <a
                    href={translatePath("/contact")}
                    class="px-6 py-2.5 bg-wood-base text-wood-bg text-sm font-medium rounded-sm hover:bg-wood-dark transition-colors"
                >
                    {t("site.callToAction.label") || "Get a Quote"}
                </a>
            </div>
        </div>

        <div class="flex md:hidden items-center gap-4">
            <LanguagePicker />
            <button
                id="menu-open"
                class="text-wood-dark p-2"
                aria-label="Open Menu"
            >
                <Icon name="lucide:menu" class="w-8 h-8" />
            </button>
        </div>
    </div>
</header>

<div
    id="mobile-menu"
    class="fixed top-0 left-0 w-screen h-[100dvh] z-[9999] bg-wood-bg translate-x-full transition-transform duration-300 ease-in-out hidden flex-col md:hidden"
>
    <div
        class="h-20 px-6 flex items-center justify-between border-b border-wood-light/10 shrink-0"
    >
        <span class="text-xl font-heading font-bold text-wood-dark"
            >{t("site.brandName")}</span
        >
        <button
            id="menu-close"
            class="text-wood-dark p-2"
            aria-label="Close Menu"
        >
            <Icon name="lucide:x" class="w-9 h-9" />
        </button>
    </div>

    <nav
        class="flex-1 flex flex-col items-center justify-center p-8 gap-10 overflow-y-auto bg-wood-bg text-center"
    >
        <div class="w-full flex flex-col items-center gap-8">
            {
                t("site.navLinks").map((link: any) => (
                    <a
                        href={translatePath(link.href)}
                        class="text-4xl font-heading text-wood-text active:text-wood-base transition-colors py-2 w-full text-center"
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>

        <div class="w-full max-w-xs flex flex-col gap-6">
            <a
                href={translatePath("/contact")}
                class="w-full py-5 bg-wood-base text-wood-bg text-center text-2xl font-bold rounded-sm active:bg-wood-dark shadow-lg"
            >
                {t("site.callToAction.label") || "Get a Quote"}
            </a>

            <div
                class="flex items-center justify-between p-5 border border-wood-light/20 rounded-sm w-full"
            >
                <span class="text-wood-text text-lg font-medium">Dark Mode</span
                >
                <button id="mobile-theme-toggle" class="p-2 text-wood-dark">
                    <Icon name="lucide:sun" class="w-7 h-7 theme-icon-sun" />
                    <Icon name="lucide:moon" class="w-7 h-7 theme-icon-moon" />
                </button>
            </div>
        </div>
    </nav>
</div>

<script>
    function setupMenu() {
        const menuOpen = document.getElementById("menu-open");
        const menuClose = document.getElementById("menu-close");
        const mobileMenu = document.getElementById("mobile-menu");
        const themeToggles = [
            document.getElementById("theme-toggle"),
            document.getElementById("mobile-theme-toggle"),
        ];

        // Theme Toggle Logic
        themeToggles.forEach((btn) => {
            btn?.addEventListener("click", () => {
                const element = document.documentElement;
                element.classList.toggle("dark");
                localStorage.setItem(
                    "theme",
                    element.classList.contains("dark") ? "dark" : "light",
                );
            });
        });

        // Open Menu
        menuOpen?.addEventListener("click", () => {
            mobileMenu?.classList.remove("hidden");
            setTimeout(() => {
                mobileMenu?.classList.remove("translate-x-full");
            }, 10);
            document.body.style.overflow = "hidden";
        });

        // Close Menu
        const closeMenu = () => {
            mobileMenu?.classList.add("translate-x-full");
            document.body.style.overflow = "";
            setTimeout(() => {
                mobileMenu?.classList.add("hidden");
            }, 300);
        };

        menuClose?.addEventListener("click", closeMenu);

        // Auto-close on Link Click
        mobileMenu?.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
    }

    setupMenu();
</script>
