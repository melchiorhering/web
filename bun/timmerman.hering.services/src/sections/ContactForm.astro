---
// src/sections/ContactForm.astro
import Section from "@components/layout/Section.astro";

import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const contactData = t("contact") as any;
---

<Section class="pt-10 pb-20 lg:pt-16 lg:pb-24">
    <div class="mb-6 text-center">
        <h1 class="text-5xl font-heading text-wood-dark mb-4">
            {t("contact.title") || "Let's Build Something"}
        </h1>
        <p class="text-lg text-wood-text max-w-2xl mx-auto">
            {
                t("contact.subtitle") ||
                    "Fill out the details below to give us an idea of your project. The estimator will provide a rough starting price, and we'll be in touch to discuss the exact details."
            }
        </p>
    </div>

    <form
        action="#"
        method="POST"
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start"
    >
        <div
            class="space-y-5 bg-white p-6 lg:p-8 rounded-md shadow-sm border border-wood-light/20"
        >
            <h2 class="text-2xl font-heading text-wood-dark mb-4">
                {t("contact.formTitle") || "Your Details"}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label
                        for="name"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{t("contact.form.name") || "Full Name"}</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="name"
                        required
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50"
                    />
                </div>
                <div>
                    <label
                        for="email"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{t("contact.form.email") || "Email Address"}</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50"
                    />
                </div>
            </div>

            <div>
                <label
                    for="phone"
                    class="block text-sm font-medium text-wood-text mb-2"
                    >{
                        t("contact.form.phone") || "Phone Number (Optional)"
                    }</label
                >
                <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50"
                />
            </div>

            <div>
                <label
                    for="description"
                    class="block text-sm font-medium text-wood-text mb-2"
                    >{
                        t("contact.form.description") || "Project Description"
                    }</label
                >
                <textarea
                    id="description"
                    name="description"
                    rows="5"
                    required
                    placeholder={t("contact.form.placeholder") ||
                        "Tell us about your vision, dimensions, and where it will go..."}
                    class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base focus:ring-1 focus:ring-wood-base outline-none transition-colors bg-wood-bg/50 resize-y"
                ></textarea>
            </div>
        </div>

        <div
            class="flex flex-col bg-wood-bg p-6 lg:p-8 rounded-md border-2 border-wood-base/20 sticky top-24 max-h-[calc(100vh-6rem)]"
        >
            <div class="shrink-0 mb-5">
                <h2 class="text-2xl font-heading text-wood-dark mb-2">
                    {t("contact.estimator.title") || "Project Estimator"}
                </h2>
                <p class="text-sm text-wood-text/80">
                    {
                        t("contact.estimator.subtitle") ||
                            "Select your options below to get a rough baseline estimate."
                    }
                </p>
            </div>

            <div class="flex-1 overflow-y-auto space-y-5 pr-2">
                <div>
                    <label
                        for="project-type"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{
                            t("contact.estimator.typeLabel") ||
                                "Type of Project"
                        }</label
                    >
                    <select
                        id="project-type"
                        name="project_type"
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base outline-none bg-white estimator-input"
                    >
                        {
                            contactData.estimator?.projectTypes?.map(
                                (type: any) => (
                                    <option
                                        value={type.value}
                                        data-base={type.basePrice}
                                    >
                                        {type.label}
                                    </option>
                                ),
                            )
                        }
                    </select>
                </div>

                <div>
                    <label
                        for="material"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{
                            t("contact.estimator.materialLabel") ||
                                "Preferred Material"
                        }</label
                    >
                    <select
                        id="material"
                        name="material"
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base outline-none bg-white estimator-input"
                    >
                        {
                            contactData.estimator?.materials?.map(
                                (material: any) => (
                                    <option
                                        value={material.value}
                                        data-mult={material.multiplier}
                                    >
                                        {material.label}
                                    </option>
                                ),
                            )
                        }
                    </select>
                </div>

                <div>
                    <label
                        for="size"
                        class="block text-sm font-medium text-wood-text mb-2"
                        >{
                            t("contact.estimator.sizeLabel") ||
                                "Approximate Size"
                        }</label
                    >
                    <select
                        id="size"
                        name="size"
                        class="w-full px-4 py-2.5 rounded-sm border border-wood-light/50 focus:border-wood-base outline-none bg-white estimator-input"
                    >
                        {
                            contactData.estimator?.sizes?.map((size: any) => (
                                <option
                                    value={size.value}
                                    data-mult={size.multiplier}
                                >
                                    {size.label}
                                </option>
                            ))
                        }
                    </select>
                </div>
            </div>

            <div class="shrink-0 mt-6 pt-5 border-t border-wood-light/30">
                <p
                    class="text-sm font-medium text-wood-text/80 uppercase tracking-wider mb-1"
                >
                    {
                        t("contact.estimator.estimateLabel") ||
                            "Estimated Starting Price"
                    }
                </p>
                <div
                    class="text-4xl lg:text-5xl font-heading text-wood-dark flex items-baseline gap-2"
                >
                    <span>€</span>
                    <span id="price-display">0</span>
                    <span class="text-xl text-wood-text/60 font-sans">+</span>
                </div>
                <p class="text-xs text-wood-text/60 mt-2 mb-5 leading-relaxed">
                    {
                        t("contact.estimator.disclaimer") ||
                            "*This is a rough baseline estimate for materials and labor. Final quotes require a detailed consultation."
                    }
                </p>

                <button
                    type="submit"
                    class="w-full px-8 py-3.5 bg-wood-base text-wood-bg font-medium rounded-sm hover:bg-wood-dark transition-colors duration-300 text-lg shadow-sm"
                >
                    {t("contact.form.submit") || "Submit Request"}
                </button>
            </div>
        </div>
    </form>
</Section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const typeSelect = document.getElementById(
            "project-type",
        ) as HTMLSelectElement;
        const materialSelect = document.getElementById(
            "material",
        ) as HTMLSelectElement;
        const sizeSelect = document.getElementById("size") as HTMLSelectElement;
        const priceDisplay = document.getElementById("price-display");

        function calculatePrice() {
            if (!typeSelect || !materialSelect || !sizeSelect) return;
            const selectedType = typeSelect.options[typeSelect.selectedIndex];
            const selectedMaterial =
                materialSelect.options[materialSelect.selectedIndex];
            const selectedSize = sizeSelect.options[sizeSelect.selectedIndex];

            const basePrice = parseFloat(
                selectedType?.getAttribute("data-base") || "0",
            );
            const materialMultiplier = parseFloat(
                selectedMaterial?.getAttribute("data-mult") || "1",
            );
            const sizeMultiplier = parseFloat(
                selectedSize?.getAttribute("data-mult") || "1",
            );

            const total = basePrice * materialMultiplier * sizeMultiplier;

            let start = parseInt(
                (priceDisplay!.textContent || "0").replace(/,/g, ""),
            );
            const end = Math.round(total);
            const duration = 300;
            const steps = 15;
            const stepTime = Math.abs(Math.floor(duration / steps));
            const increment = (end - start) / steps;

            let current = start;
            const timer = setInterval(() => {
                current += increment;
                priceDisplay!.textContent =
                    Math.round(current).toLocaleString("en-NL");
                if (
                    (increment > 0 && current >= end) ||
                    (increment < 0 && current <= end)
                ) {
                    priceDisplay!.textContent = end.toLocaleString("en-NL");
                    clearInterval(timer);
                }
            }, stepTime);
        }

        const inputs = document.querySelectorAll(".estimator-input");
        inputs.forEach((input) => {
            input.addEventListener("change", calculatePrice);
        });

        // Wait a tiny bit to ensure the DOM is fully populated before calculating
        setTimeout(calculatePrice, 50);
    });
</script>
