---
// src/pages/projects/[id].astro
import Layout from "@layouts/Layout.astro";
import Section from "@components/layout/Section.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const projects = await getCollection("projects");

    return projects.map((project: CollectionEntry<"projects">) => {
        // Split "en/bank-simpel" into lang="en" and slug="bank-simpel"
        const [lang, ...slugParts] = project.id.split("/");
        const slug = slugParts.join("/");

        return {
            params: { lang, id: slug },
            props: { project },
        };
    });
}

const { project } = Astro.props;

// 1. Separate the language from the folder name
const [lang, ...slugParts] = project.id.split("/");
const slug = slugParts.join("/");

let finalCoverImage = project.data.coverImage;
let finalGalleryImages = project.data.gallery || [];

if (!finalCoverImage && finalGalleryImages.length === 0) {
    const allLocalImages = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/images/projects/**/*.{jpeg,jpg,png,webp}",
        { eager: true },
    );

    // 2. Search using ONLY the slug
    const localPaths = Object.keys(allLocalImages).filter((path) =>
        path.includes(`/projects/${slug}/`),
    );

    const coverPath = localPaths.find((path) => path.includes("/cover."));
    if (coverPath)
        finalCoverImage = allLocalImages[coverPath]
            .default as unknown as string;

    const galleryPaths = localPaths.filter((path) => path !== coverPath);
    finalGalleryImages = galleryPaths.map(
        (path) => allLocalImages[path].default as unknown as string,
    );
}

// Combine the cover and gallery images for the top slider
const carouselImages = finalCoverImage
    ? [finalCoverImage, ...finalGalleryImages]
    : finalGalleryImages;
---

<Layout title={project.data.title} description={project.data.description}>
    <Section>
        <a
            href="/#gallery"
            class="text-wood-base hover:text-wood-dark mb-6 inline-block font-medium"
        >
            &larr; Back to all projects
        </a>

        <div class="mb-8">
            <div
                class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-3"
            >
                <h1 class="text-3xl md:text-4xl font-heading text-wood-dark">
                    {project.data.title}
                </h1>
                <span
                    class="font-medium text-wood-text/60 text-sm sm:text-base mt-1 sm:mt-0 whitespace-nowrap"
                >
                    Completed: {project.data.completionYear}
                </span>
            </div>

            <p class="text-lg text-wood-text max-w-3xl leading-relaxed">
                {project.data.description}
            </p>
        </div>

        {/* --- DYNAMIC COVER SLIDESHOW --- */}
        {
            carouselImages.length > 0 && (
                <div class="relative w-full rounded-md overflow-hidden mb-16 bg-wood-light/5 border border-wood-light/20 shadow-sm group/slider">
                    <div
                        id="cover-slider-track"
                        class="flex transition-transform duration-500 ease-out h-full"
                    >
                        {carouselImages.map((img, index) => (
                            <div
                                class="w-full shrink-0 flex justify-center py-8 relative group"
                                data-slide={index}
                            >
                                <Image
                                    src={img}
                                    alt={`View ${index + 1} of ${project.data.title}`}
                                    class="w-full max-w-250 h-auto max-h-[65vh] object-contain rounded-sm drop-shadow-md cursor-pointer lightbox-trigger transition-transform duration-700 group-hover:scale-[1.02]"
                                    width={1200}
                                    height={675}
                                />
                                <div class="absolute inset-0 pointer-events-none flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 group-hover:bg-wood-dark/10">
                                    <div class="bg-white/95 text-wood-dark p-4 rounded-full shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                        <Icon
                                            name="lucide:zoom-in"
                                            class="w-6 h-6"
                                        />
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>

                    {carouselImages.length > 1 && (
                        <>
                            <button
                                id="slider-prev"
                                class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white text-wood-dark p-3 rounded-full shadow-md opacity-0 group-hover/slider:opacity-100 transition-all duration-300 hover:scale-110 focus:outline-none"
                                aria-label="Previous image"
                            >
                                <Icon
                                    name="lucide:chevron-left"
                                    class="w-6 h-6"
                                />
                            </button>
                            <button
                                id="slider-next"
                                class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white text-wood-dark p-3 rounded-full shadow-md opacity-0 group-hover/slider:opacity-100 transition-all duration-300 hover:scale-110 focus:outline-none"
                                aria-label="Next image"
                            >
                                <Icon
                                    name="lucide:chevron-right"
                                    class="w-6 h-6"
                                />
                            </button>

                            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
                                {carouselImages.map((_, idx) => (
                                    <button
                                        class="slider-dot w-2.5 h-2.5 rounded-full transition-all duration-300 focus:outline-none"
                                        data-target={idx}
                                        aria-label={`Go to slide ${idx + 1}`}
                                    />
                                ))}
                            </div>
                        </>
                    )}
                </div>
            )
        }

        {/* --- MASONRY GALLERY --- */}
        {
            finalGalleryImages.length > 0 && (
                <div class="mt-8">
                    <div class="flex items-center gap-4 mb-8">
                        <h2 class="text-2xl font-heading text-wood-dark m-0">
                            Project Gallery
                        </h2>
                        <div class="h-px bg-wood-light/40 flex-1 mt-1" />
                    </div>
                    <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
                        {finalGalleryImages.map((img, index) => (
                            <div class="relative group rounded-md overflow-hidden bg-wood-light/10 shadow-sm border border-wood-light/20 break-inside-avoid">
                                <Image
                                    src={img}
                                    alt={`Detail shot ${index + 1} of ${project.data.title}`}
                                    class="w-full h-auto object-cover cursor-pointer lightbox-trigger transition-transform duration-700 group-hover:scale-105"
                                    width={800}
                                    height={800}
                                />
                                <div class="absolute inset-0 pointer-events-none flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 group-hover:bg-wood-dark/20">
                                    <div class="bg-white/95 text-wood-dark p-3 rounded-full shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                        <Icon
                                            name="lucide:zoom-in"
                                            class="w-5 h-5"
                                        />
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            )
        }
    </Section>

    {/* --- UPGRADED LIGHTBOX UI --- */}
    <dialog
        id="lightbox"
        class="bg-transparent m-auto max-w-[100vw] max-h-screen w-full h-full p-4 md:p-8 backdrop:bg-black/95 backdrop:backdrop-blur-sm focus:outline-none"
    >
        <button
            id="lightbox-close"
            class="fixed top-6 right-6 md:top-10 md:right-10 text-white/80 hover:text-white transition-colors z-50 focus:outline-none"
            aria-label="Close fullscreen image"
        >
            <Icon name="lucide:x" class="w-10 h-10 drop-shadow-md" />
        </button>

        <button
            id="lightbox-prev"
            class="fixed left-2 sm:left-6 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors z-50 focus:outline-none hidden sm:block"
            aria-label="Previous image"
        >
            <Icon name="lucide:chevron-left" class="w-12 h-12 drop-shadow-lg" />
        </button>

        <button
            id="lightbox-next"
            class="fixed right-2 sm:right-6 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors z-50 focus:outline-none hidden sm:block"
            aria-label="Next image"
        >
            <Icon
                name="lucide:chevron-right"
                class="w-12 h-12 drop-shadow-lg"
            />
        </button>

        <div class="w-full h-full flex items-center justify-center">
            <img
                id="lightbox-img"
                src=""
                alt="Fullscreen view"
                class="max-w-full max-h-full object-contain rounded-sm shadow-2xl scale-95 opacity-0 transition-all duration-300"
            />
        </div>
    </dialog>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. LIGHTBOX LOGIC ---
        const dialog = document.getElementById("lightbox") as HTMLDialogElement;
        const dialogImg = document.getElementById(
            "lightbox-img",
        ) as HTMLImageElement;
        const closeBtn = document.getElementById("lightbox-close");
        const lbPrevBtn = document.getElementById("lightbox-prev");
        const lbNextBtn = document.getElementById("lightbox-next");

        // Turn the NodeList into a true Array so we can navigate by index
        const triggers = Array.from(
            document.querySelectorAll(".lightbox-trigger"),
        ) as HTMLImageElement[];
        let currentLightboxIndex = 0;

        const openLightbox = (index: number) => {
            if (!dialog || !dialogImg) return;
            currentLightboxIndex = index;
            const targetImg = triggers[currentLightboxIndex];

            dialogImg.src = targetImg.src;
            dialogImg.alt = targetImg.alt;
            dialog.showModal();
            document.body.style.overflow = "hidden";

            setTimeout(() => {
                dialogImg.classList.remove("scale-95", "opacity-0");
                dialogImg.classList.add("scale-100", "opacity-100");
            }, 10);
        };

        const changeLightboxImage = (direction: "next" | "prev") => {
            if (direction === "next") {
                currentLightboxIndex =
                    (currentLightboxIndex + 1) % triggers.length;
            } else {
                currentLightboxIndex =
                    (currentLightboxIndex - 1 + triggers.length) %
                    triggers.length;
            }

            // Fast fade effect between images
            dialogImg.classList.remove("opacity-100", "scale-100");
            dialogImg.classList.add("opacity-0", "scale-95");

            setTimeout(() => {
                const targetImg = triggers[currentLightboxIndex];
                dialogImg.src = targetImg.src;
                dialogImg.alt = targetImg.alt;

                dialogImg.classList.remove("opacity-0", "scale-95");
                dialogImg.classList.add("opacity-100", "scale-100");
            }, 200);
        };

        if (dialog && dialogImg) {
            triggers.forEach((trigger, idx) => {
                trigger.addEventListener("click", () => openLightbox(idx));
            });

            const closeLightbox = () => {
                dialogImg.classList.remove("scale-100", "opacity-100");
                dialogImg.classList.add("scale-95", "opacity-0");
                setTimeout(() => {
                    dialog.close();
                    document.body.style.overflow = "";
                    dialogImg.src = "";
                }, 300);
            };

            closeBtn?.addEventListener("click", closeLightbox);
            lbNextBtn?.addEventListener("click", () =>
                changeLightboxImage("next"),
            );
            lbPrevBtn?.addEventListener("click", () =>
                changeLightboxImage("prev"),
            );

            dialog.addEventListener("click", (e) => {
                if (e.target === dialog) closeLightbox();
            });
            dialog.addEventListener("cancel", (e) => {
                e.preventDefault();
                closeLightbox();
            });
        }

        // --- 2. SLIDER LOGIC ---
        const track = document.getElementById("cover-slider-track");
        const prevBtn = document.getElementById("slider-prev");
        const nextBtn = document.getElementById("slider-next");
        const dots = document.querySelectorAll(".slider-dot");

        let currentSlide = 0;
        let totalSlides = dots.length;

        const updateSlider = () => {
            if (!track) return;
            track.style.transform = `translateX(-${currentSlide * 100}%)`;
            dots.forEach((dot, idx) => {
                if (idx === currentSlide) {
                    dot.classList.add("bg-wood-dark", "scale-110");
                    dot.classList.remove("bg-wood-dark/30");
                } else {
                    dot.classList.remove("bg-wood-dark", "scale-110");
                    dot.classList.add("bg-wood-dark/30");
                }
            });
        };

        if (track && totalSlides > 0) {
            nextBtn?.addEventListener("click", () => {
                currentSlide = (currentSlide + 1) % totalSlides;
                updateSlider();
            });

            prevBtn?.addEventListener("click", () => {
                currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
                updateSlider();
            });

            dots.forEach((dot, idx) => {
                dot.addEventListener("click", () => {
                    currentSlide = idx;
                    updateSlider();
                });
            });
            updateSlider();
        }

        // --- 3. GLOBAL KEYBOARD NAVIGATION ---
        document.addEventListener("keydown", (e) => {
            if (dialog && dialog.open) {
                // If Lightbox is open, navigate the Lightbox Gallery
                if (e.key === "ArrowRight") changeLightboxImage("next");
                if (e.key === "ArrowLeft") changeLightboxImage("prev");
            } else if (track && totalSlides > 1) {
                // If Lightbox is closed, navigate the inline Slider
                if (e.key === "ArrowRight") nextBtn?.click();
                if (e.key === "ArrowLeft") prevBtn?.click();
            }
        });
    });
</script>
