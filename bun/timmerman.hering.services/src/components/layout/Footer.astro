---
// src/components/layout/Footer.astro
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const currentYear = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteData = t("site") as any;
const contactData = t("contact") as any;
---

<footer class="w-full bg-wood-dark text-wood-bg py-16 mt-12">
    <div
        class="max-w-300 mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-8"
    >
        <div class="flex flex-col space-y-4">
            <h3 class="text-2xl font-heading text-wood-light">
                {siteData.brandName}
            </h3>
            <p class="text-wood-bg/80 text-sm max-w-xs leading-relaxed">
                {siteData.description}
            </p>
        </div>

        <div>
            <h4
                class="font-bold mb-4 uppercase text-sm tracking-wider text-wood-light"
            >
                {t("footer.quickLinks") || "Quick Links"}
            </h4>
            <ul class="space-y-3 text-sm text-wood-bg/80">
                {
                    siteData.navLinks.map((link: any) => (
                        <li>
                            <a
                                href={link.href}
                                class="hover:text-wood-light transition-colors"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>

        <div>
            <h4
                class="font-bold mb-4 uppercase text-sm tracking-wider text-wood-light"
            >
                {t("footer.contact") || "Contact"}
            </h4>
            <address class="not-italic text-sm text-wood-bg/80 space-y-2">
                <p>{contactData.city}, {contactData.region}</p>
                <p>{contactData.country}</p>
                <p class="pt-2">
                    <a
                        href={`mailto:${contactData.email}`}
                        class="hover:text-wood-light transition-colors"
                    >
                        {contactData.email}
                    </a>
                </p>
            </address>
        </div>
    </div>

    <div
        class="max-w-300 mx-auto px-6 mt-16 pt-8 border-t border-wood-light/20 text-center text-sm text-wood-bg/60"
    >
        &copy; {currentYear}
        {siteData.brandName}. All rights reserved.
    </div>
</footer>
