---
import Action from "@/components/Action.astro";
import Icon from "@/components/Icon.astro";
import type { HeroData } from "@/config/landing.interface";
import type { Icon as IconType } from "@/config/landing.interface";

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section
  id="hero-section"
  class="relative flex justify-center h-screen w-screen bg-cover bg-center"
  style=`background-image: url(${data.backgroundImageSrc})`>
  <div
    class="relative z-10 flex flex-col items-center justify-center text-center pt-32">
    <!-- Title with Line Divider -->
    <h1
      class="text-5xl font-semibold md:text-6xl flex flex-col md:flex-row items-center justify-between md:gap-x-4">
      <!-- Text -->
      <span class="text-white font-bold w-full">{data.title}</span>
      <!-- Divider Line -->
      <Icon
        class="md:h-48 md:w-48 h-20 w-20"
        icon={data.dividerIcon as IconType}
      />
      <span class="text-black font-bold w-full">{data.highlightedTitle}</span>
    </h1>

    <!-- Subtitle -->
    <h2 class="mt-10 text-lg text-white md:text-2xl">
      {data.subTitle}
    </h2>

    <!-- Action Buttons -->
    <div
      class="flex mt-10 flex-col md:flex-row space-y-4 md:space-y-0 md:space-x-8 justify-center items-center">
      <Action
        as="a"
        type="baseClass"
        class="flex text-white bg-black shadow-inner-lg w-48 h-12 justify-center items-center rounded-lg font-bold hover:scale-110 hover:opacity-90 transition"
        href="#"
        target="_blank">
        {data.primaryCta}
      </Action>
      <Action
        as="a"
        type="baseClass"
        class="flex text-black bg-white shadow-inner-lg w-48 h-12 justify-center items-center rounded-lg font-bold hover:scale-110 hover:opacity-90 transition"
        href="#"
        target="_blank">
        {data.secondaryCta}
      </Action>
    </div>

    <!-- Arrow Down with Text -->
    <div class="flex flex-col items-center justify-center md:mt-32 mt-10">
      <p class="text-white font-bold text-sm mb-4 pb-2 md:text-base">
        {data.downwardArrowText}
      </p>
      <Action
        as="a"
        class="flex items-center justify-center text-center text-white transition border-2 border-transparent rounded-full animate-bounce bg-primary w-14 h-14 hover:bg-white hover:text-primary hover:border-primary"
        href="#services-section"
        title="Scroll to gallery">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-8 h-8">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
        </svg>
      </Action>
    </div>
  </div>
  <!-- Optional Overlay bg-image -->
  <div class="absolute inset-0 bg-black bg-opacity-50"></div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #hero-section {
    opacity: 0;
    animation: fadeIn 0.8s ease-in-out forwards;
  }
</style>
