---
// src/layouts/Layout.astro
import "../styles/global.css";
import { SEO } from "astro-seo";
import Header from "../components/layout/Header.astro";
// import Footer from "./components/layout/Footer.astro";

export interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = "favicon.jpg" } = Astro.props;

// --- SEO Configuration ---
// Define site-wide constants here to keep them organized.
const siteName = "Timmerman"; // Or "Timmerman"
const titleTemplate = `%s | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Basic Meta Tags (non-SEO) -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {
      /* The SEO component from astro-seo.
        The Twitter section has been removed.
    */
    }
    <SEO
      title={title}
      titleTemplate={titleTemplate}
      description={description}
      canonical={Astro.url.href}
      openGraph={{
        basic: {
          title: title, // Using the page title as a default for OG title
          type: "website",
          image: image,
          url: Astro.url.href,
        },
        optional: {
          // Added the OG description, which was missing before.
          description: description,
          // Corrected site_name to siteName and moved to 'optional' as per docs.
          siteName: siteName,
        },
        image: {
          // It's best practice to provide alt text for the social image.
          alt: `Social media preview for ${title}`,
        },
      }}
    />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/jpg" href="/favicon.jpg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
      <!-- Or a footer here -->
      <!-- <Footer /> -->
    </main>
  </body>
</html>
