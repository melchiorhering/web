---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import ThemeToggle from "./ThemeToggle.astro";

// --- Fetch dynamic header data ---
const headerData = await getEntry("header", "config");
const { logo, brandName, navLinks = [], contactButton } = headerData.data;

// --- STYLE VARIABLES (unchanged) ---
const navLinkClasses =
    "font-semibold text-base transition hover:text-primary px-4 py-3";
const contactButtonClasses =
    "flex items-center justify-center gap-2 rounded-lg px-8 py-3 font-bold text-primary transition hover:bg-primary hover:text-white";
---

<header
    id="header"
    class="fixed top-0 z-50 w-full bg-background/98 shadow-md transition-colors duration-300"
>
    <div
        class="mx-auto flex h-18 items-center justify-between px-6 md:h-18 md:px-24"
    >
        <a href="/" class="flex items-center gap-3">
            {
                logo && (
                    <Image
                        src={logo}
                        alt={`${brandName} Logo`}
                        width={36}
                        height={36}
                    />
                )
            }
            <span class="text-xl font-bold text-[var(--color-text-base)]"
                >{brandName}</span
            >
        </a>

        <div class="flex items-center gap-2 md:gap-6">
            <nav aria-label="Desktop Navigation" class="hidden md:block">
                <ul class="flex items-center gap-2 text-base">
                    {
                        navLinks.map((link) => (
                            <li>
                                <a class={navLinkClasses} href={link.path}>
                                    {link.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
            <div class="flex items-center gap-2">
                {
                    contactButton && (
                        <a
                            href={contactButton.path}
                            class:list={[
                                contactButtonClasses,
                                "hidden md:flex",
                            ]}
                        >
                            <span>{contactButton.text}</span>
                            <Icon
                                name="mdi:email-edit-outline"
                                class="h-6 w-6"
                            />
                        </a>
                    )
                }

                <ThemeToggle />

                <button
                    id="hamburger-button"
                    class="relative flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-text-muted transition hover:bg-fill-muted hover:text-text-base md:hidden"
                    aria-label="Toggle Menu"
                    aria-expanded="false"
                >
                    <span class="sr-only">Toggle menu</span>
                    <Icon
                        name="mdi:hamburger-menu"
                        class="hamburger-icon h-6 w-6"
                    />
                    <Icon
                        name="mdi:window-close"
                        class="close-icon hidden h-6 w-6"
                    />
                </button>
            </div>
        </div>
    </div>

    <div
        id="mobile-menu"
        class:list={[
            "absolute top-16 left-0 w-full border-t border-border bg-background transition-all duration-300 ease-in-out md:hidden md:top-20",
            "-translate-y-full opacity-0 invisible",
            "[&.is-menu-open]:translate-y-0 [&.is-menu-open]:opacity-100 [&.is-menu-open]:visible",
        ]}
    >
        <nav aria-label="Mobile Navigation" class="flow-root">
            <ul
                class="flex flex-col items-stretch gap-4 border-y-2 border-y-primary px-6 py-4"
            >
                {
                    navLinks.map((link) => (
                        <li class="text-center">
                            <a class={navLinkClasses} href={link.path}>
                                {link.name}
                            </a>
                        </li>
                    ))
                }

                {
                    contactButton && (
                        <li>
                            <a
                                href={contactButton.path}
                                class:list={[contactButtonClasses, "w-full"]}
                            >
                                <span>{contactButton.text}</span>
                                <Icon
                                    name="mdi:email-edit-outline"
                                    class="h-6 w-6"
                                />
                            </a>
                        </li>
                    )
                }
            </ul>
        </nav>
    </div>
</header>

<script>
    const hamburgerButton = document.getElementById("hamburger-button");
    const mobileMenu = document.getElementById("mobile-menu");
    // Get the new icon elements
    const hamburgerIcon = document.querySelector(".hamburger-icon");
    const closeIcon = document.querySelector(".close-icon");

    if (hamburgerButton && mobileMenu && hamburgerIcon && closeIcon) {
        hamburgerButton.addEventListener("click", () => {
            // Toggle the menu visibility
            mobileMenu.classList.toggle("is-menu-open");

            // Toggle which icon is shown
            hamburgerIcon.classList.toggle("hidden");
            closeIcon.classList.toggle("hidden");

            // Update ARIA attribute for accessibility
            const isExpanded =
                hamburgerButton.getAttribute("aria-expanded") === "true";
            hamburgerButton.setAttribute("aria-expanded", String(!isExpanded));

            // Prevent background scroll when menu is open
            document.body.classList.toggle("overflow-hidden");
        });
    }
</script>
