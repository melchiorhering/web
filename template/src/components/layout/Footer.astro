---
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";

const footerConfig = await getEntry("footer", "config");
const { linkGroups, socialLinks, copyrightText } = footerConfig.data;
const currentYear = new Date().getFullYear();

// Combine all link groups into a single array for simpler mapping
const allLinks = linkGroups.flatMap((group) => group.links);
---

<footer
    class="border-t-4 border-primary bg-fill-muted text-text-base px-8 py-10"
>
    <div class="container mx-auto">
        <div
            class="flex flex-col md:flex-row justify-between items-center gap-8"
        >
            <nav>
                <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2">
                    {
                        allLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-sm font-bold uppercase tracking-wider text-text-muted transition-colors hover:text-primary"
                                >
                                    {link.text}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <div class="flex gap-x-5">
                {
                    socialLinks.map((social) => (
                        <a
                            href={social.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-text-muted transition-transform hover:scale-110 hover:text-primary"
                            aria-label={`Visit our ${social.iconName.split(":")[1]} page`}
                        >
                            <Icon name={social.iconName} class="w-6 h-6" />
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="mt-10 pt-6 border-t border-border text-center">
            <p class="text-xs text-text-muted">
                &copy; {currentYear}
                {copyrightText}. All rights reserved.
            </p>
        </div>
    </div>
</footer>
