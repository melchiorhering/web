---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

// Fetch data safely, providing default empty values.
const footerConfig = await getEntry("footer", "config");
const {
    linkGroups = [],
    copyrightText = "Timmerman",
    logo,
} = footerConfig?.data || {};
const currentYear = new Date().getFullYear();

const allLinks = linkGroups.flatMap((group) => group.links);
---

<footer class="bg-fill-muted rounded-lg shadow-sm px-4">
    <div class="w-full max-w-screen-xl mx-auto p-4 md:py-8">
        <div class="sm:flex sm:items-center sm:justify-between">
            <a href="/" class="flex items-center gap-x-3 mb-4 sm:mb-0">
                {
                    logo ? (
                        // If a logo is provided, render the Image component
                        <Image
                            src={logo}
                            alt={`${copyrightText} Logo`}
                            class="h-8 w-auto"
                        />
                    ) : (
                        // Otherwise, fall back to the geometric shape
                        <div class="h-7 w-7 bg-primary rounded-sm" />
                    )
                }

                <span
                    class="self-center text-2xl font-bold whitespace-nowrap text-text-base"
                >
                    {copyrightText}
                </span>
            </a>

            {
                allLinks.length > 0 && (
                    <ul class="flex flex-wrap items-center mb-6 text-sm font-medium text-text-muted sm:mb-0">
                        {allLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="hover:text-primary font-extrabold transition-colors me-4 md:me-6"
                                >
                                    {link.text}
                                </a>
                            </li>
                        ))}
                    </ul>
                )
            }
        </div>

        <hr class="my-6 border-border sm:mx-auto lg:my-8" />

        <span class="block text-sm text-text-muted sm:text-center">
            &copy; {currentYear}
            <a href="/" class="hover:text-primary transition-colors"
                >{copyrightText}™</a
            >. All Rights Reserved.
        </span>
    </div>
</footer>
