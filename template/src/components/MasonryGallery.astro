---
import { Icon } from "astro-icon/components";
interface Entry {
    image: string; // The image source path
    alt: string;
}

interface Props {
    entries: Entry[];
}

const aspectRatios = ["aspect-square", "aspect-3/2", "aspect-4/3"];

const { entries } = Astro.props;
---

<div
    id="lightbox"
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4 opacity-0 invisible transition-opacity duration-300"
>
    <button
        id="lightbox-close"
        class="absolute right-4 top-4 z-10 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:close" class="h-8 w-8" />
    </button>
    <button
        id="lightbox-prev"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-10 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:chevron-left" class="h-8 w-8" />
    </button>
    <button
        id="lightbox-next"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-10 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:chevron-right" class="h-8 w-8" />
    </button>
    <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[90%] max-w-[90%] rounded-md shadow-2xl"
    />
</div>

<div class="h-full">
    <div class="columns-1 md:columns-3 gap-8 space-y-6">
        {
            entries.map((item, index) => {
                const randomAspect =
                    aspectRatios[
                        Math.floor(Math.random() * aspectRatios.length)
                    ];
                return (
                    <div
                        class="cursor-pointer"
                        data-image-src={item.image.src}
                        data-image-alt={item.alt}
                        data-index={index}
                    >
                        <img
                            src={item.image.src}
                            alt={item.alt}
                            loading="lazy"
                            decoding="async"
                            class:list={[
                                "w-full rounded-lg shadow-lg object-cover",
                                randomAspect,
                            ]}
                        />
                    </div>
                );
            })
        }
    </div>
</div>

<script>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");
    const galleryItems = document.querySelectorAll("[data-index]");

    const images = Array.from(galleryItems).map((item) => ({
        src: item.getAttribute("data-image-src"),
        alt: item.getAttribute("data-image-alt"),
    }));

    let currentIndex = 0;

    function showImage(index) {
        if (!lightbox || !lightboxImage || !images[index]) return;
        lightboxImage.src = images[index].src;
        lightboxImage.alt = images[index].alt;
        currentIndex = index;
    }

    function openLightbox(index) {
        if (!lightbox) return;
        showImage(index);
        lightbox.classList.remove("invisible", "opacity-0");
        document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
        if (!lightbox) return;
        lightbox.classList.add("invisible", "opacity-0");
        document.body.style.overflow = "";
    }

    function showNextImage() {
        showImage((currentIndex + 1) % images.length);
    }

    function showPrevImage() {
        showImage((currentIndex - 1 + images.length) % images.length);
    }

    galleryItems.forEach((item, index) => {
        item.addEventListener("click", () => openLightbox(index));
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightboxPrev?.addEventListener("click", showPrevImage);
    lightboxNext?.addEventListener("click", showNextImage);

    lightbox?.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (e) => {
        if (lightbox?.classList.contains("invisible")) return;
        if (e.key === "ArrowRight") showNextImage();
        if (e.key === "ArrowLeft") showPrevImage();
        if (e.key === "Escape") closeLightbox();
    });
</script>
