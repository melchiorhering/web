---
import { Icon } from "astro-icon/components";

interface Entry {
    image: { src: string };
    alt: string;
}

interface Props {
    entries: Entry[];
    columns?: number;
}

const { entries, columns = 4 } = Astro.props;

const columnEntries: { entry: Entry; originalIndex: number }[][] = Array.from(
    { length: columns },
    () => [],
);

entries.forEach((entry, index) => {
    const columnIndex = index % columns;
    columnEntries[columnIndex].push({ entry, originalIndex: index });
});
---

<div
    id="lightbox"
    class="fixed inset-0 flex h-screen items-center justify-center bg-black/80 p-4 opacity-0 invisible transition-opacity duration-300"
>
    <button
        id="lightbox-close"
        class="absolute right-4 top-4 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:close" class="h-8 w-8" />
    </button>
    <button
        id="lightbox-prev"
        class="absolute left-4 top-1/2 -translate-y-1/2 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:chevron-left" class="h-8 w-8" />
    </button>
    <button
        id="lightbox-next"
        class="absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:chevron-right" class="h-8 w-8" />
    </button>
    <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[90%] max-w-[90%] rounded-md shadow-2xl"
    />
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
    {
        columnEntries.map((column) => (
            <div class="grid gap-3">
                {column.map(({ entry, originalIndex }) => (
                    <img
                        data-image-src={entry.image.src}
                        data-image-alt={entry.alt}
                        data-index={originalIndex}
                        class="cursor-pointer h-auto max-w-full object-cover object-center rounded-lg shadow-md"
                        src={entry.image.src}
                        alt={entry.alt}
                        loading="lazy"
                        decoding="async"
                    />
                ))}
            </div>
        ))
    }
</div>

<script>
    const lightbox = document.getElementById("lightbox");
    const header = document.getElementById("header");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");
    const galleryItems = document.querySelectorAll("[data-index]");

    const images = Array.from(galleryItems).map((item) => ({
        src: item.getAttribute("data-image-src"),
        alt: item.getAttribute("data-image-alt"),
    }));

    let currentIndex = 0;

    // A small update to the script to handle correct indexing with the new layout
    function findImageIndex(index) {
        return images.findIndex((img, i) => {
            const item = galleryItems[i];
            return parseInt(item.getAttribute("data-index")) === index;
        });
    }

    function showImage(index) {
        if (!lightbox || !lightboxImage) return;

        const imageToShow = images[findImageIndex(index)];
        if (!imageToShow) return;

        lightboxImage.src = imageToShow.src;
        lightboxImage.alt = imageToShow.alt;
        currentIndex = index;
    }

    function openLightbox(index) {
        if (!lightbox) return;
        showImage(index);
        lightbox.classList.remove("invisible", "opacity-0");
        header.classList.remove("z-50");
        document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
        if (!lightbox) return;
        lightbox.classList.add("invisible", "opacity-0");
        header.classList.add("z-50");
        document.body.style.overflow = "";
    }

    function showNextImage() {
        const nextIndex = (findImageIndex(currentIndex) + 1) % images.length;
        const nextOriginalIndex = parseInt(
            galleryItems[nextIndex].getAttribute("data-index"),
        );
        showImage(nextOriginalIndex);
    }

    function showPrevImage() {
        const prevIndex =
            (findImageIndex(currentIndex) - 1 + images.length) % images.length;
        const prevOriginalIndex = parseInt(
            galleryItems[prevIndex].getAttribute("data-index"),
        );
        showImage(prevOriginalIndex);
    }

    galleryItems.forEach((item) => {
        item.addEventListener("click", () => {
            const index = parseInt(item.getAttribute("data-index"), 10);
            openLightbox(index);
        });
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightboxPrev?.addEventListener("click", showPrevImage);
    lightboxNext?.addEventListener("click", showNextImage);

    lightbox?.addEventListener("click", (e) => {
        if (e.target === lightbox) {
            closeLightbox();
        }
    });

    document.addEventListener("keydown", (e) => {
        if (lightbox?.classList.contains("invisible")) return;

        if (e.key === "ArrowRight") {
            showNextImage();
        } else if (e.key === "ArrowLeft") {
            showPrevImage();
        } else if (e.key === "ArrowDown") {
            closeLightbox();
        } else if (e.key === "Escape") {
            closeLightbox();
        }
    });
</script>
