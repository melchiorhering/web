---
// src/components/ui/BauhausPipes.astro

// Define the shape of a single pipe object for clarity
interface Pipe {
    length: string;
    colorIndex: number;
}

// --- STEP 1: SIMPLIFY PROPS ---
// We've removed all the container... and zIndex props.
// We've added a single `class` prop to accept Tailwind classes.
interface Props {
    class?: string; // This will accept any string of Tailwind classes
    pipes?: Pipe[];
    pipeWidth?: string;
    pipeColor?: string;
    endColors?: string[];
    rotation?: string;
    spacing?: string;
    top?: string;
    left?: string;
}

// Default pattern (no changes here)
const defaultPipes: Pipe[] = [
    { length: "150px", colorIndex: 0 },
    { length: "180px", colorIndex: 1 },
    { length: "220px", colorIndex: 2 },
    { length: "250px", colorIndex: 0 },
    { length: "120px", colorIndex: 2 },
    { length: "160px", colorIndex: 1 },
    { length: "190px", colorIndex: 0 },
    { length: "140px", colorIndex: 2 },
    { length: "80px", colorIndex: 1 },
    { length: "100px", colorIndex: 2 },
    { length: "70px", colorIndex: 1 },
];

const {
    class: className, // Renaming `class` to `className` is a common practice to avoid conflicts
    pipes = defaultPipes,
    pipeWidth = "20px",
    pipeColor = "--color-black",
    endColors = ["--color-primary", "--color-secondary", "--color-accent"],
    rotation = "-35deg",
    spacing = "38px",
    top = "150px",
    left = "-10px",
} = Astro.props;
---

<div
    class:list={[
        // Base classes for the container. These were previously in the <style> tag.
        "w-full h-full pointer-events-none overflow-hidden",
        // Any classes passed in via the `class` prop will be added here.
        className,
    ]}
    style={`
    /* The style attribute is now much cleaner! */
    --pipe-width: ${pipeWidth};
    --pipe-color: var(${pipeColor});
    --rotation-angle: ${rotation};
    --vertical-spacing: ${spacing};
    --offset-top: ${top};
    --offset-left: ${left};
  `}
>
    {/* The pipe rendering logic remains the same */}
    {
        pipes.map((pipe, index) => {
            const endColorVarName =
                endColors[pipe.colorIndex % endColors.length];
            return (
                <div
                    class="pipe"
                    style={`
          --end-color: var(${endColorVarName});
          --pipe-index: ${index};
          --pipe-length: ${pipe.length};
        `}
                />
            );
        })
    }
</div>

<style>
    /* The .pipes-container rule is no longer needed, as its styles
    have been moved to Tailwind classes on the element itself.
  */
    .pipe {
        position: absolute;
        top: var(--offset-top);
        left: var(--offset-left);
        width: var(--pipe-length);
        height: var(--pipe-width);
        background-color: var(--pipe-color);
        border-radius: var(--pipe-width);
        transform-origin: left center;
        transform: translateY(calc(var(--pipe-index) * var(--vertical-spacing)))
            rotate(var(--rotation-angle));
        box-shadow: 4px 4px 10px rgba(0, 0, 0, 0.25);
    }
    .pipe::after {
        content: "";
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: var(--pipe-width);
        height: var(--pipe-width);
        border-radius: 50%;
        background-color: var(--end-color);
        box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
    }
</style>
