---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

// --- Config for Variants ---
// Re-added for the "scrapbook" variant to work
const masonryHeightClasses = ["h-64", "h-80", "h-96"];
// Array of rotation classes for the scrapbook effect
const rotationClasses = ["rotate-2", "-rotate-1", "rotate-1", "-rotate-2"];

const { variant = "grid", entries } = Astro.props;
---

<div
    id="lightbox"
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4 opacity-0 invisible transition-opacity duration-300"
>
    {/* Lightbox content remains the same */}
    <button
        id="lightbox-close"
        class="absolute right-4 top-4 z-10 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:close" class="h-8 w-8" />
    </button>
    <button
        id="lightbox-prev"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-10 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:chevron-left" class="h-8 w-8" />
    </button>
    <button
        id="lightbox-next"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-10 cursor-pointer rounded-full bg-slate-500/50 p-2 text-white transition hover:bg-slate-500"
    >
        <Icon name="mdi:chevron-right" class="h-8 w-8" />
    </button>
    <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[90%] max-w-[90%] rounded-md shadow-2xl"
    />
</div>

{
    variant === "grid" && (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {entries.map((item, index: number) => (
                <div
                    class="group transform cursor-pointer transition duration-300 hover:scale-105"
                    data-image-src={item.image}
                    data-image-alt={item.alt}
                    data-index={index}
                >
                    <div class="rounded-lg bg-white p-4 pb-6 shadow-lg">
                        <Image
                            src={item.image}
                            alt={item.alt}
                            class="h-80 w-full object-cover"
                        />
                        <h2 class="mt-4 text-center text-lg font-semibold text-gray-800">
                            {item.title}
                        </h2>
                    </div>
                </div>
            ))}
        </div>
    )
}

{
    variant === "scrapbook" && (
        <div class="columns-1 gap-3 space-y-3 p-4 md:columns-2 lg:columns-3 xl:columns-4">
            {entries.map((item, index: number) => {
                // FIX: heightClass was missing its definition. It is now defined here.
                const heightClass =
                    masonryHeightClasses[index % masonryHeightClasses.length];
                const rotationClass =
                    rotationClasses[index % rotationClasses.length];
                return (
                    <div
                        class:list={[
                            "group relative break-inside-avoid cursor-pointer bg-white p-2 shadow-lg transition duration-300 ease-in-out hover:z-10 hover:scale-105 hover:!rotate-0",
                            rotationClass,
                        ]}
                        data-image-src={item.image}
                        data-image-alt={item.alt}
                        data-index={index}
                    >
                        <Image
                            src={item.image}
                            alt={item.alt}
                            class:list={["w-full object-cover", heightClass]}
                        />
                        {item.photographer && (
                            <p class="absolute bottom-4 left-4 rounded bg-black/50 px-2 py-1 text-xs text-white opacity-0 transition-opacity group-hover:opacity-100">
                                Photo by {item.photographer}
                            </p>
                        )}
                    </div>
                );
            })}
        </div>
    )
}

{
    variant === "masonry" && (
        <div class="columns-1 gap-4 space-y-4 p-4 md:columns-2 lg:columns-3">
            {entries.map((item, index: number) => (
                <div
                    class="break-inside-avoid cursor-pointer"
                    data-image-src={item.image}
                    data-image-alt={item.alt}
                    data-index={index}
                >
                    <img
                        src={item.image}
                        alt={item.alt}
                        loading="lazy"
                        decoding="async"
                        class="h-auto w-full rounded-lg shadow-lg"
                    />
                </div>
            ))}
        </div>
    )
}

{
    variant === "showcase" && (
        <div class="space-y-24 md:space-y-32 p-4">
            {entries.map((item, index: number) => (
                <div class="grid grid-cols-1">
                    <div
                        class="cursor-pointer"
                        data-image-src={item.image}
                        data-image-alt={item.alt}
                        data-index={index}
                    >
                        {/* IMPROVEMENT: Switched to <img> for reliability, like the masonry variant */}
                        <img
                            src={item.image}
                            alt={item.alt}
                            loading="lazy"
                            decoding="async"
                            class="w-full"
                        />
                    </div>
                    <div class="container mx-auto px-8 text-center">
                        <h2 class="text-3xl font-bold">{item.title}</h2>
                        <p class="mx-auto mt-4 max-w-2xl text-text-muted">
                            {item.alt}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    )
}

<script>
    // Lightbox elements
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");

    // Gallery items
    const galleryItems = document.querySelectorAll("[data-index]");
    // Create an array of image data from the DOM
    const images = Array.from(galleryItems).map((item) => ({
        src: item.getAttribute("data-image-src"),
        alt: item.getAttribute("data-image-alt"),
    }));

    let currentIndex = 0;

    function showImage(index) {
        if (!lightbox || !lightboxImage) return;

        const image = images[index];
        if (!image) return;

        lightboxImage.src = image.src;
        lightboxImage.alt = image.alt;
        currentIndex = index;
    }

    function openLightbox(index) {
        if (!lightbox) return;
        showImage(index);
        lightbox.classList.remove("invisible", "opacity-0");
        document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
        if (!lightbox) return;
        lightbox.classList.add("invisible", "opacity-0");
        document.body.style.overflow = "";
    }

    function showNextImage() {
        const nextIndex = (currentIndex + 1) % images.length;
        showImage(nextIndex);
    }

    function showPrevImage() {
        const prevIndex = (currentIndex - 1 + images.length) % images.length;
        showImage(prevIndex);
    }

    // Add click listeners to gallery items
    galleryItems.forEach((item) => {
        item.addEventListener("click", () => {
            const index = parseInt(item.getAttribute("data-index"), 10);
            openLightbox(index);
        });
    });

    // Add listeners for lightbox controls
    lightboxClose?.addEventListener("click", closeLightbox);
    lightboxPrev?.addEventListener("click", showPrevImage);
    lightboxNext?.addEventListener("click", showNextImage);

    lightbox?.addEventListener("click", (e) => {
        if (e.target === lightbox) {
            closeLightbox();
        }
    });

    // Add keyboard navigation
    document.addEventListener("keydown", (e) => {
        if (lightbox.classList.contains("invisible")) return;

        if (e.key === "ArrowRight") {
            showNextImage();
        } else if (e.key === "ArrowLeft") {
            showPrevImage();
        } else if (e.key === "Escape") {
            closeLightbox();
        }
    });
</script>
