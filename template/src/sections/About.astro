---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro:assets";

interface Props {
    title: string;
    intro: string;
    features?: string[];
    image: ImageMetadata;
    imageAlt?: string;
    cta?: {
        text: string;
        href: string;
    };
}

const {
    title,
    intro,
    features = [],
    image,
    imageAlt = "A descriptive photo for the about section.",
    cta,
} = Astro.props;
---

<section class="relative overflow-hidden bg-background py-20 md:py-32">
    <div
        class="absolute top-0 left-0 h-64 w-64 -translate-x-1/2 rounded-full bg-primary/5"
    >
    </div>
    <div class="absolute bottom-0 right-0 h-32 w-1 bg-secondary/20"></div>

    <div class="container relative mx-auto px-8">
        <div
            class="grid grid-cols-1 items-center gap-12 md:grid-cols-5 lg:gap-20"
        >
            <div class="md:col-span-3">
                <div class="mb-6 h-1 w-20 bg-secondary"></div>
                <h2
                    class="text-4xl font-bold leading-tight text-text-base md:text-5xl"
                >
                    {title}
                </h2>
                <p class="mt-6 text-lg leading-relaxed text-text-muted">
                    {intro}
                </p>

                {
                    features.length > 0 && (
                        <ul class="mt-8 space-y-4 text-text-muted">
                            {features.map((feature) => (
                                <li class="flex items-start gap-x-4">
                                    <div class="mt-1.5 h-3 w-3 flex-shrink-0 rounded-sm bg-secondary" />
                                    <span>{feature}</span>
                                </li>
                            ))}
                        </ul>
                    )
                }

                {
                    cta && (
                        <div class="mt-10">
                            <a
                                href={cta.href}
                                class="inline-block bg-primary px-8 py-3 font-bold text-white transition hover:bg-opacity-90"
                            >
                                {cta.text}
                            </a>
                        </div>
                    )
                }
            </div>

            <div class="md:col-span-2 flex items-center justify-center p-4">
                <div
                    class="relative w-full max-w-[300px] h-auto"
                    style={{ aspectRatio: image.width / image.height }}
                >
                    <div
                        class="absolute inset-0 -rotate-3 transform rounded-lg bg-accent"
                    >
                    </div>

                    <Image
                        src={image}
                        alt={imageAlt}
                        class="relative h-full w-full rotate-1 transform rounded-lg object-cover shadow-2xl"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
