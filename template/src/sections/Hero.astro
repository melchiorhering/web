---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import BauhausPipes from "../components/ui/BauhausPipes.astro";

const config = await getEntry("hero", "config");
const { title, subtitle, button, heroImage, bauhausPipes } = config.data;
---

<section
    class="relative flex w-full flex-col overflow-hidden md:h-screen md:flex-row"
>
    <div class="absolute h-full w-full rounded-r-xl bg-hero md:w-1/3"></div>
    <BauhausPipes
        pipes={bauhausPipes}
        class="absolute top-6 -left-24 md:left-0 lg:pl-8"
    />

    <div
        class="flex h-screen w-full items-center justify-center p-8 md:h-full md:w-1/3 md:justify-start md:p-16 lg:p-24"
    >
        <div
            class="w-full rounded-bl-[100px] rounded-tr-[100px] border-b-[10px] border-l-[10px] border-secondary bg-fill-muted/95 p-12 shadow-2xl transition hover:rotate-0 md:w-auto md:-rotate-1"
        >
            <h1
                class="text-4xl font-bold text-text-base md:text-5xl lg:text-6xl"
                set:html={title}
            />
            <p class="mt-4 max-w-md text-lg text-text-muted">{subtitle}</p>
            <a
                href={button.href}
                class="mt-8 inline-block rounded-lg bg-primary px-6 py-3 font-bold text-white transition hover:bg-opacity-90"
            >
                {button.text}
            </a>
        </div>
    </div>

    <div
        class="relative flex h-screen w-full items-center justify-center md:h-full md:w-2/3 md:p-8 md:pr-24"
    >
        <Image
            src={heroImage.src}
            alt={heroImage.alt}
            class="h-full w-full object-cover md:h-auto md:max-h-[90%] md:w-auto md:rounded-xl md:shadow-2xl md:p-8 px-2 rounded-xl bg-image-background"
        />
    </div>

    <div
        class="absolute right-0 top-0 hidden h-screen w-16 items-center justify-center overflow-hidden p-2 shadow-lg md:flex"
        style={`
            background-image: repeating-linear-gradient(
                90deg,
                var(--color-secondary),
                var(--color-secondary) 2px,
                transparent 3px,
                transparent 6px
            );
        `}
    >
        <div
            class="whitespace-nowrap [writing-mode:vertical-rl] rotate-180 bg-hero px-2 py-0.5"
        >
            {
                Array.from({ length: 10 }).map(() => (
                    <span class=" text-black font-extrabold uppercase text-sm">
                        Handcrafted in Amsterdam
                    </span>
                ))
            }
        </div>
    </div>
</section>
