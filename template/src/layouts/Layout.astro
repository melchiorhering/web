---
// src/layouts/Layout.astro
import "../styles/global.css";
import { SEO } from "astro-seo";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
// import Footer from "../components/layout/Footer.astro";

export interface Props {
    title: string;
    description: string;
    image?: string;
}

const { title, description, image = "favicon.jpg" } = Astro.props;

const siteName = "Timmerman";
const titleTemplate = `%s | ${siteName}`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />

        <!-- Theme Toggle -->
        <script is:inline>
            const theme = (() => {
                if (
                    typeof localStorage !== "undefined" &&
                    localStorage.getItem("theme")
                ) {
                    return localStorage.getItem("theme");
                }
                if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                    return "dark";
                }
                return "light";
            })();

            if (theme === "light") {
                // No attribute needed for light mode
                document.documentElement.removeAttribute("data-theme");
            } else {
                document.documentElement.setAttribute("data-theme", "dark");
            }
        </script>

        <SEO
            title={title}
            titleTemplate={titleTemplate}
            description={description}
            canonical={Astro.url.href}
            openGraph={{
                basic: {
                    title: title,
                    type: "website",
                    image: image,
                    url: Astro.url.href,
                },
                optional: {
                    description: description,
                    siteName: siteName,
                },
                image: {
                    alt: `Social media preview for ${title}`,
                },
            }}
        />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="icon" type="image/jpg" href="/favicon.jpg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap"
            rel="stylesheet"
        />
    </head>

    <body class="font-bauhaus">
        <div class="flex min-h-screen flex-col">
            <Header />
            <slot name="after-header" />
            <main class="mx-auto w-full pb-8">
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
